# DevAssist environment configuration (development)
# Copy this file to `.env` before running `docker-compose up`.

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
LOG_LEVEL=debug

# ── Authentication ───────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
BCRYPT_ROUNDS=12

# ── PostgreSQL (local Docker; use RDS connection string in prod) ──
DATABASE_URL=postgres://devassist:devassist@postgres:5432/devassist

# ── Redis (local Docker; use ElastiCache endpoint in prod) ───
REDIS_URL=redis://redis:6379

# ── AI engine ────────────────────────────────────────────────
AI_ENGINE_API_KEY=replace-with-engine-key
AI_ENGINE_MODEL=replace-with-engine-model-id
AI_ENGINE_MAX_TOKENS=4096

# ── AWS — used by S3, SES, CloudWatch, Lambda triggers ───────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=devassist-history-dev
SES_FROM_EMAIL=no-reply@devassist.local
CLOUDWATCH_LOG_GROUP=/devassist/api
CLOUDWATCH_LOG_STREAM=local

# ── Rate limits ──────────────────────────────────────────────
RATE_LIMIT_AI_PER_MIN=20
