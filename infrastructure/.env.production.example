# DevAssist production environment template
# Copyright (c) 2024 Hemang Parmar
#
# Copy to /opt/devassist/.env on the EC2 host (or inject via SSM Parameter
# Store / Secrets Manager during deploy). Never commit real values.

# Application
NODE_ENV=production
PORT=4000
FRONTEND_ORIGIN=https://app.devassist.example.com
LOG_LEVEL=info

# Authentication
JWT_SECRET=__set_via_ssm__
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
BCRYPT_ROUNDS=12

# RDS PostgreSQL (sslmode=require triggers TLS in pg pool)
DATABASE_URL=postgres://devassist:__pwd__@devassist-prod.cxxxx.us-east-1.rds.amazonaws.com:5432/devassist?sslmode=require

# ElastiCache Redis
REDIS_URL=redis://devassist-prod.xxxxx.0001.use1.cache.amazonaws.com:6379

# AI engine
AI_ENGINE_API_KEY=__set_via_ssm__
AI_ENGINE_MODEL=__set_via_ssm__
AI_ENGINE_MAX_TOKENS=4096

# AWS — credentials provided by the EC2 instance role; only the region is needed here.
AWS_REGION=us-east-1
S3_BUCKET=devassist-history-prod
SES_FROM_EMAIL=no-reply@devassist.example.com
CLOUDWATCH_LOG_GROUP=/devassist/api
CLOUDWATCH_LOG_STREAM=ec2

# Rate limits
RATE_LIMIT_AI_PER_MIN=20
